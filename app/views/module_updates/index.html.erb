<% content_for(:title) { "Module Updates — #{@module_definition.display_name} — Factor Fifty" } %>

<div style="margin-bottom:20px;">
  <%= link_to "← Back to #{@module_definition.display_name}", module_path(@module_definition), style: "font-size:12px;color:var(--text-secondary);text-decoration:none;" %>
</div>

<div class="page-header">
  <div>
    <h1 class="page-title">Module Updates</h1>
    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Version history and upgrade management for <%= @module_definition.display_name %>.</p>
  </div>
  <div class="header-actions">
    <%= form_with url: check_updates_module_updates_path(@module_definition), method: :post, local: true, style: "display:flex;gap:8px;align-items:center;" do %>
      <input type="text" name="new_ref" class="mod-input mod-input--mono" placeholder="v2.0.0 or main" value="main" style="width:180px;padding:6px 10px;font-size:12px;">
      <button type="submit" class="btn btn-green btn-sm">Check for Updates</button>
    <% end %>
  </div>
</div>

<%# Version list %>
<% @versions.each do |version| %>
  <div class="mod-panel" style="margin-bottom:16px;">
    <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
      <span style="font-weight:600;font-family:var(--font-mono);font-size:13px;"><%= version.version_ref %></span>
      <% if version.breaking? %>
        <span class="mod-status-badge mod-status-deprecated"><span class="mod-status-dot"></span>⚠ BREAKING</span>
      <% else %>
        <span class="mod-status-badge mod-status-live"><span class="mod-status-dot"></span>Non-breaking</span>
      <% end %>
      <span style="margin-left:auto;font-size:11px;color:var(--text-muted);">Scanned <%= time_ago_in_words(version.scanned_at) %> ago</span>
    </div>

    <% report = version.compatibility_report %>
    <% if report.present? %>
      <div style="padding:14px 18px;">
        <% (report["added"] || []).each do |v| %>
          <div style="font-size:12px;font-family:var(--font-mono);padding:4px 0;color:#56d490;">
            + <%= v["name"] %> (<%= v["type"] %><%= ", default: #{v["default"]}" if v["default"] %>)
            <% if v["breaking"] %>
              <span class="mod-status-badge mod-status-deprecated" style="font-size:9px;padding:1px 6px;margin-left:6px;"><span class="mod-status-dot"></span>required, no default</span>
            <% end %>
          </div>
        <% end %>

        <% (report["removed"] || []).each do |v| %>
          <div style="font-size:12px;font-family:var(--font-mono);padding:4px 0;color:#fc8181;">
            ✕ Removed: <%= v["name"] %>
          </div>
        <% end %>

        <% (report["changed"] || []).each do |v| %>
          <div style="font-size:12px;font-family:var(--font-mono);padding:4px 0;color:var(--orange);">
            ~ <%= v["name"] %>:
            <% (v["changes"] || {}).each do |key, change| %>
              <%= key %> <%= change["from"] %> → <%= change["to"] %>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Affected resources %>
      <% affected = @affected_resources.select(&:upgrade_available?) %>
      <% if affected.any? %>
        <div style="padding:0 18px 14px;border-top:1px solid var(--border);margin-top:0;padding-top:14px;">
          <h4 style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Affected resources (<%= affected.size %>)</h4>
          <% affected.each do |resource| %>
            <div style="display:flex;align-items:center;gap:8px;padding:6px 0;font-size:12px;">
              <span style="color:var(--text-primary);">● <%= resource.local_environment.env_type %> / <%= resource.name %></span>
              <% if resource.local_environment.upgrade_policy == "locked" %>
                <span class="mod-status-badge mod-status-draft" style="font-size:10px;padding:1px 6px;">🔒 Locked</span>
              <% elsif version.breaking? %>
                <span class="mod-status-badge" style="font-size:10px;padding:1px 6px;background:var(--orange-dim);color:var(--orange);border:1px solid rgba(245,158,11,0.2);">⚠ Manual review</span>
              <% else %>
                <span class="mod-status-badge mod-status-live" style="font-size:10px;padding:1px 6px;">Can upgrade</span>
                <%= form_with url: upgrade_resource_module_update_path(@module_definition, version), method: :post, local: true, style: "display:inline;" do %>
                  <input type="hidden" name="resource_id" value="<%= resource.id %>">
                  <button type="submit" class="mod-action-btn mod-action-btn-primary" style="font-size:11px;">Upgrade</button>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <% unless version.breaking? %>
            <div style="margin-top:12px;">
              <%= form_with url: upgrade_all_module_updates_path(@module_definition), method: :post, local: true do %>
                <button type="submit" class="btn btn-green btn-sm">Upgrade All Compatible</button>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if @versions.empty? %>
  <%= render "shared/empty_state", icon: "📦", title: "No version history", description: "Use \"Check for Updates\" to scan a new version." %>
<% end %>
