<% content_for(:title) { "Global Tags — Factor Fifty" } %>

<div class="page-header">
  <div>
    <h1 class="page-title">Global Tags</h1>
    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">
      Manage tags at different hierarchy levels. Lower levels override higher levels on key conflicts.
    </p>
  </div>
  <div class="gt-header-stat">
    <span><%= @tags.select(&:enabled?).count %></span> active / <span><%= @tags.count %></span> total at this level
  </div>
</div>

<%# Scope selector bar %>
<div class="gt-scope-bar">
  <div class="gt-scope-label">Scope Level</div>
  <select class="gt-form-select" style="max-width:240px;"
          onchange="if(this.value==='platform'){window.location='<%= global_tags_path %>'}else{var parts=this.value.split(':');window.location='<%= global_tags_path %>?scope_type='+parts[0]+'&scope_id='+parts[1]}">
    <% @all_levels.each do |lvl| %>
      <option value="<%= lvl[:type] ? "#{lvl[:type]}:#{lvl[:id]}" : "platform" %>"
              <%= "selected" if lvl[:current] %>>
        <%= lvl[:label] %>
      </option>
    <% end %>
  </select>
  <% if @scope_record %>
    <div class="gt-scope-pill gt-scope-pill--scoped">
      <div class="gt-scope-pill-dot"></div>
      Editing: <%= @scope_record.class.name.sub("Local", "") %> level
    </div>
  <% else %>
    <div class="gt-scope-pill gt-scope-pill--platform">
      <div class="gt-scope-pill-dot"></div>
      Platform level (applies to all)
    </div>
  <% end %>
</div>

<%# Tags table %>
<div class="gt-table-card">
  <% if @tags.any? %>
    <table>
      <thead>
        <tr>
          <th>Key</th>
          <th>Value</th>
          <th>Description</th>
          <th style="text-align:right">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @tags.each do |tag| %>
          <tr>
            <td><span class="mono"><%= tag.key %></span></td>
            <td><span class="mono"><%= tag.value %></span></td>
            <td style="color:var(--text-muted);"><%= tag.description.present? ? tag.description : "—" %></td>
            <td>
              <div style="display:flex;justify-content:flex-end;gap:8px;align-items:center;">
                <div class="gt-row-actions">
                  <%= button_to tag.enabled? ? "Disable" : "Enable",
                      toggle_global_tag_path(tag), method: :patch,
                      class: "gt-row-btn",
                      params: { scope_type: @scope_type, scope_id: @scope_id }.compact_blank %>
                  <%= button_to "Delete", global_tag_path(tag),
                      method: :delete, class: "gt-row-btn gt-row-btn--danger",
                      data: { turbo_confirm: "Delete tag '#{tag.key}'?" },
                      params: { scope_type: @scope_type, scope_id: @scope_id }.compact_blank %>
                </div>
                <% if tag.enabled? %>
                  <span class="gt-status-badge gt-status-active"><span class="gt-status-dot"></span>Active</span>
                <% else %>
                  <span class="gt-status-badge gt-status-disabled"><span class="gt-status-dot"></span>Disabled</span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="gt-empty">No tags at this level. Add one below or select a different scope.</div>
  <% end %>
</div>

<%# Add tag form panel %>
<div class="gt-form-panel">
  <div class="gt-form-panel-header">
    <div class="gt-form-panel-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
    </div>
    <div class="gt-form-panel-title">Add Tag at <%= @scope_record ? @scope_record.class.name.sub("Local", "") : "Platform" %> Level</div>
  </div>
  <div class="gt-form-body">
    <%= form_with url: global_tags_path(scope_type: @scope_type, scope_id: @scope_id), method: :post, local: true do %>
      <% if @scope_type.present? %>
        <input type="hidden" name="scope_type" value="<%= @scope_type %>">
        <input type="hidden" name="scope_id" value="<%= @scope_id %>">
      <% end %>
      <div class="gt-form-row gt-form-row--halves">
        <div class="gt-form-group">
          <label class="gt-form-label">Key <span class="req">*</span></label>
          <input type="text" name="key" class="gt-form-input gt-form-input--mono"
                 placeholder="e.g. managed-by" required
                 pattern="[a-zA-Z0-9_\-:\/\.]+"
                 title="Only alphanumeric, hyphens, underscores, colons, slashes, and dots">
        </div>
        <div class="gt-form-group">
          <label class="gt-form-label">Value <span class="req">*</span></label>
          <input type="text" name="value" class="gt-form-input gt-form-input--mono"
                 placeholder="e.g. factorfifty" required>
        </div>
      </div>
      <div class="gt-form-group">
        <label class="gt-form-label">Description</label>
        <textarea name="description" class="gt-form-textarea"
                  placeholder="Optional — why this tag exists"></textarea>
      </div>
      <div>
        <button type="submit" class="btn btn-green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Tag
        </button>
      </div>
    <% end %>
  </div>
</div>

<%# Inherited tags from parent levels (only shown when viewing a non-platform scope) %>
<% if @scope_record %>
  <%
    inherited = []
    case @scope_record
    when LocalEnvironment
      project = @scope_record.local_project
      customer = project.local_customer
      reseller = customer.local_reseller
      inherited << { level: "Platform", tags: GlobalTag.platform.by_key }
      inherited << { level: "Reseller (#{reseller.name})", tags: GlobalTag.for_taggable(reseller).by_key } if reseller
      inherited << { level: "Customer (#{customer.name})", tags: GlobalTag.for_taggable(customer).by_key }
      inherited << { level: "Project (#{project.name})", tags: GlobalTag.for_taggable(project).by_key }
    when LocalProject
      customer = @scope_record.local_customer
      reseller = customer.local_reseller
      inherited << { level: "Platform", tags: GlobalTag.platform.by_key }
      inherited << { level: "Reseller (#{reseller.name})", tags: GlobalTag.for_taggable(reseller).by_key } if reseller
      inherited << { level: "Customer (#{customer.name})", tags: GlobalTag.for_taggable(customer).by_key }
    when LocalCustomer
      reseller = @scope_record.local_reseller
      inherited << { level: "Platform", tags: GlobalTag.platform.by_key }
      inherited << { level: "Reseller (#{reseller.name})", tags: GlobalTag.for_taggable(reseller).by_key } if reseller
    when LocalReseller
      inherited << { level: "Platform", tags: GlobalTag.platform.by_key }
    end
    inherited.reject! { |l| l[:tags].empty? }
  %>
  <% if inherited.any? %>
    <div class="gt-inherited-panel">
      <div class="gt-inherited-header">
        <div class="gt-inherited-title">Inherited Tags</div>
        <div class="gt-inherited-desc">
          Tags from parent levels. These are read-only here — edit them at their own scope level.
          Tags at this level override inherited tags with the same key.
        </div>
      </div>
      <div class="gt-inherited-body">
        <% inherited.each do |group| %>
          <div class="gt-inherited-group">
            <div class="gt-inherited-level-label"><%= group[:level] %></div>
            <div class="gt-inherited-tags">
              <% group[:tags].each do |tag| %>
                <% overridden = @tags.any? { |t| t.key == tag.key } %>
                <div class="gt-inherited-tag<%= ' gt-inherited-tag--overridden' if overridden %>">
                  <code style="color:var(--text-primary);"><%= tag.key %></code>
                  <span style="color:var(--text-muted);">=</span>
                  <code style="color:var(--text-secondary);"><%= tag.value %></code>
                  <% if overridden %>
                    <span class="overridden-label">OVERRIDDEN</span>
                  <% end %>
                  <% unless tag.enabled? %>
                    <span class="disabled-label">DISABLED</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
