<% content_for(:title) { "Git Credentials — Factor Fifty" } %>

<div class="page-header">
  <div>
    <h1 class="page-title">Git Credentials</h1>
    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Manage credentials for accessing module Git repositories.</p>
  </div>
</div>

<%# Expiration warning banner %>
<% expiring = @credentials.select { |c| c.expires_at && c.expires_at < 7.days.from_now && c.active? } %>
<% if expiring.any? %>
  <div style="background:var(--orange-dim);border:1px solid rgba(245,158,11,0.3);border-radius:var(--radius);padding:10px 16px;margin-bottom:20px;font-size:13px;color:var(--orange);">
    ⚠ <%= expiring.size %> credential(s) expiring within 7 days: <%= expiring.map(&:name).join(", ") %>
  </div>
<% end %>

<%# Credentials table %>
<% if @credentials.any? %>
  <div class="mod-table-wrap" style="margin-bottom:24px;">
    <table class="mod-tbl">
      <thead>
        <tr>
          <th>Name</th>
          <th>Host</th>
          <th>Type</th>
          <th>Scope</th>
          <th>Expires</th>
          <th>Status</th>
          <th>Used by</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @credentials.each do |cred| %>
          <tr class="mod-tbl__row">
            <td><span style="font-weight:500;"><%= cred.name %></span></td>
            <td><span class="mod-version-text"><%= cred.host %></span></td>
            <td><span class="mod-renderer-badge mod-renderer-tofu"><%= cred.credential_type.titleize %></span></td>
            <td><span style="font-size:12px;color:var(--text-secondary);"><%= cred.scope %></span></td>
            <td>
              <% if cred.expires_at %>
                <% if cred.expires_at < Time.current %>
                  <span class="mod-status-badge mod-status-deprecated"><span class="mod-status-dot"></span>Expired</span>
                <% elsif cred.expires_at < 30.days.from_now %>
                  <span class="mod-status-badge" style="background:var(--orange-dim);color:var(--orange);border:1px solid rgba(245,158,11,0.2);">
                    <span class="mod-status-dot" style="background:var(--orange);"></span>
                    <%= distance_of_time_in_words_to_now(cred.expires_at) %>
                  </span>
                <% else %>
                  <span style="font-size:12px;color:var(--text-muted);"><%= cred.expires_at.strftime("%Y-%m-%d") %></span>
                <% end %>
              <% else %>
                <span style="font-size:12px;color:var(--text-muted);">—</span>
              <% end %>
            </td>
            <td>
              <% if cred.active? %>
                <span class="mod-status-badge mod-status-live"><span class="mod-status-dot"></span>Active</span>
              <% else %>
                <span class="mod-status-badge mod-status-draft"><span class="mod-status-dot"></span>Inactive</span>
              <% end %>
            </td>
            <td><span style="font-size:12px;color:var(--text-muted);"><%= cred.module_renderers.count %> renderer(s)</span></td>
            <td>
              <div class="mod-actions-cell">
                <button class="mod-action-btn"
                        data-action="click->credential-actions#verify"
                        data-credential-actions-url-value="<%= verify_git_credential_path(cred) %>">
                  Verify
                </button>
                <button class="mod-action-btn"
                        data-action="click->credential-actions#rotate"
                        data-credential-actions-url-value="<%= rotate_git_credential_path(cred) %>">
                  Rotate
                </button>
                <%= button_to "Delete", git_credential_path(cred, confirm: "true"),
                    method: :delete, class: "mod-action-btn",
                    style: "color:var(--red);",
                    data: { turbo_confirm: "Delete credential '#{cred.name}'? This may affect #{cred.module_renderers.count} module(s)." } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state", icon: "🔑", title: "No credentials yet", description: "Add a credential below to get started." %>
<% end %>

<%# Add new credential form %>
<div class="mod-panel" style="margin-top:24px;">
  <div style="padding:14px 18px;border-bottom:1px solid var(--border);">
    <h3 style="font-size:13px;font-weight:600;">Add Credential</h3>
  </div>
  <div style="padding:18px;">
    <%= form_with url: git_credentials_path, method: :post, local: true do %>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px;">
        <div class="mod-field mod-field--req">
          <label class="mod-field__label" for="cred_name">Name</label>
          <input type="text" name="name" id="cred_name" class="mod-input" placeholder="Acme Corp GitHub" required>
        </div>
        <div class="mod-field mod-field--req">
          <label class="mod-field__label" for="cred_host">Host</label>
          <input type="text" name="host" id="cred_host" class="mod-input" placeholder="github.com" required>
        </div>
        <div class="mod-field">
          <label class="mod-field__label" for="cred_type">Type</label>
          <select name="credential_type" id="cred_type" class="mod-select">
            <% GitCredential::CREDENTIAL_TYPES.each do |ct| %>
              <option value="<%= ct %>"><%= ct.titleize %></option>
            <% end %>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px;">
        <div class="mod-field mod-field--req">
          <label class="mod-field__label" for="cred_token">Token</label>
          <input type="password" name="token" id="cred_token" class="mod-input mod-input--mono" placeholder="ghp_****" required>
        </div>
        <div class="mod-field">
          <label class="mod-field__label" for="cred_expires">Expires</label>
          <input type="date" name="expires_at" id="cred_expires" class="mod-input">
        </div>
      </div>
      <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;">ⓘ Token is encrypted at rest. F50 only needs read access (read_repository scope).</p>
      <button type="submit" class="btn btn-green btn-sm">Save Credential</button>
    <% end %>
  </div>
</div>
