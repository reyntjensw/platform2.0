<div class="page-content">
  <div class="page-header">
    <h1 class="page-title">Git Credentials</h1>
    <p class="page-subtitle">Manage credentials for accessing module Git repositories</p>
  </div>

  <%# Expiration warning banner %>
  <% expiring = @credentials.select { |c| c.expires_at && c.expires_at < 7.days.from_now && c.active? } %>
  <% if expiring.any? %>
    <div class="alert alert--warning">
      ⚠ <%= expiring.size %> credential(s) expiring within 7 days: <%= expiring.map(&:name).join(", ") %>
    </div>
  <% end %>

  <%# Credentials list %>
  <div class="credentials-grid">
    <% @credentials.each do |cred| %>
      <div class="credential-card">
        <div class="credential-card__header">
          <span class="credential-card__name"><%= cred.name %></span>
          <span class="meta-tag"><%= cred.credential_type.titleize %></span>
          <% if cred.active? %>
            <span class="meta-tag meta-tag--ready">Active</span>
          <% else %>
            <span class="meta-tag meta-tag--error">Inactive</span>
          <% end %>
        </div>
        <div class="credential-card__body">
          <p><strong>Host:</strong> <%= cred.host %></p>
          <p><strong>Scope:</strong> <%= cred.scope %></p>
          <% if cred.last_verified_at %>
            <p><strong>Last verified:</strong> <%= time_ago_in_words(cred.last_verified_at) %> ago</p>
          <% end %>
          <% if cred.expires_at %>
            <p>
              <strong>Expires:</strong>
              <% if cred.expires_at < Time.current %>
                <span class="text-danger">Expired</span>
              <% elsif cred.expires_at < 30.days.from_now %>
                <span class="text-warning"><%= distance_of_time_in_words_to_now(cred.expires_at) %></span>
              <% else %>
                <%= cred.expires_at.strftime("%Y-%m-%d") %>
              <% end %>
            </p>
          <% end %>
          <p><strong>Used by:</strong> <%= cred.module_renderers.count %> module renderer(s)</p>
        </div>
        <div class="credential-card__actions">
          <button class="f50-btn f50-btn--secondary f50-btn--sm"
                  data-action="click->credential-actions#verify"
                  data-credential-actions-url-value="<%= verify_git_credential_path(cred) %>">
            Verify
          </button>
          <button class="f50-btn f50-btn--secondary f50-btn--sm"
                  data-action="click->credential-actions#rotate"
                  data-credential-actions-url-value="<%= rotate_git_credential_path(cred) %>">
            Rotate
          </button>
          <%= button_to "Delete", git_credential_path(cred, confirm: "true"),
              method: :delete, class: "f50-btn f50-btn--danger f50-btn--sm",
              data: { turbo_confirm: "Delete credential '#{cred.name}'? This may affect #{cred.module_renderers.count} module(s)." } %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Add new credential form %>
  <div class="detail-section">
    <h2 class="section-title">Add Credential</h2>
    <%= form_with url: git_credentials_path, method: :post, local: true, class: "credential-form" do %>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="cred_name">Name</label>
          <input type="text" name="name" id="cred_name" class="f50-input" placeholder="Acme Corp GitHub" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="cred_host">Host</label>
          <input type="text" name="host" id="cred_host" class="f50-input" placeholder="github.com" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="cred_type">Type</label>
          <select name="credential_type" id="cred_type" class="f50-select">
            <% GitCredential::CREDENTIAL_TYPES.each do |ct| %>
              <option value="<%= ct %>"><%= ct.titleize %></option>
            <% end %>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group form-group--wide">
          <label class="form-label" for="cred_token">Token</label>
          <input type="password" name="token" id="cred_token" class="f50-input" placeholder="ghp_****" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="cred_expires">Expires</label>
          <input type="date" name="expires_at" id="cred_expires" class="f50-input">
        </div>
      </div>
      <p class="form-hint">ⓘ Token is encrypted at rest. F50 only needs read access (read_repository scope).</p>
      <button type="submit" class="f50-btn f50-btn--primary">Save Credential</button>
    <% end %>
  </div>
</div>
