<% content_for(:title, "React Test — Factor Fifty") %>

<div style="padding: 24px;">
  <h1 style="font-size: 20px; font-weight: 600; margin-bottom: 16px;">React Mounting Test</h1>

  <p style="color: var(--text-secondary, #8b99b5); margin-bottom: 24px;">
    The component below is mounted via the Stimulus <code>react_controller</code>.
  </p>

  <%# React component mounted via Stimulus react_controller %>
  <div data-controller="react"
       data-react-component-value="HelloWorld"
       data-react-props-value="<%= { name: 'Factor Fifty' }.to_json %>">
  </div>

  <%# Also test with default props (no props attribute) %>
  <div data-controller="react"
       data-react-component-value="HelloWorld">
  </div>
</div>
