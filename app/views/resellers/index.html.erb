<% content_for(:title) { "Select Reseller — Factor Fifty" } %>

<div class="page-header">
  <div>
    <h1 class="page-title">Resellers</h1>
  </div>
</div>

<% if @resellers.any? %>
  <div class="entity-grid">
    <% @resellers.each_with_index do |reseller, i| %>
      <% color = %w[#4fc3f7 #56d490 #f6ad55 #a78bfa #fc8181 #39d2c0][i % 6] %>
      <% initials = reseller.name.to_s.split.map(&:first).join.upcase.first(2) %>
      <%= link_to customers_path(reseller_uuid: reseller.uuid), class: "entity-card", style: "--accent-color: #{color};", data: { turbo: false } do %>
        <div class="entity-card-top">
          <div class="entity-card-icon" style="background: <%= color %>1a; color: <%= color %>;"><%= initials %></div>
          <div class="entity-card-badges">
            <% if reseller.inactive? %>
              <span class="entity-badge entity-badge-inactive">Inactive</span>
            <% else %>
              <span class="entity-badge entity-badge-active">Active</span>
            <% end %>
          </div>
        </div>
        <div class="entity-card-name"><%= reseller.name %></div>
        <div class="entity-card-meta"><%= reseller.vat_number.presence || "—" %></div>
        <div class="entity-card-footer">
          <div class="entity-card-stat">
            <div class="entity-card-dot" style="background: #56d490;"></div>
            Customers
          </div>
          <span class="entity-card-arrow">→</span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
    icon: "🏢",
    title: "No resellers found",
    description: "There are no resellers available." %>
<% end %>
