<% content_for(:title) { "#{@project.name} — Factor Fifty" } %>

<% current_tab = params[:tab].to_s %>
<% current_tab = "environments" if current_tab.blank? %>
<% provider = @project.provider&.downcase %>
<% base_path = customer_project_path(params[:customer_uuid], @project.uuid) %>

<% if current_tab == "credentials" && provider == "azure" %>
  <%# ═══════════════════════════════════════════════════
      Azure Credentials
      ═══════════════════════════════════════════════════ %>
  <div data-controller="azure-credentials"
       data-action="keydown@document->azure-credentials#closeOnEscape"
       data-azure-credentials-list-url-value="<%= customer_project_azure_credentials_path(params[:customer_uuid], @project.uuid) %>"
       data-azure-credentials-test-url-value="<%= test_customer_project_azure_credentials_path(params[:customer_uuid], @project.uuid) %>"
       data-azure-credentials-create-url-value="<%= customer_project_azure_credentials_path(params[:customer_uuid], @project.uuid) %>"
       data-azure-credentials-customer-uuid-value="<%= @customer.uuid %>"
       data-azure-credentials-project-uuid-value="<%= @project.uuid %>">

    <h2 style="font-size:18px;font-weight:700;margin-bottom:4px;">Azure Credentials</h2>
    <p style="font-size:12px;color:var(--text-secondary);margin-bottom:20px;">Manage Azure service principal credentials for this project.</p>

    <% if can_manage_resource? %>
      <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
        <button class="btn btn-green btn-sm" data-action="click->azure-credentials#openAdd">+ Add Credential</button>
      </div>
    <% end %>

    <div data-azure-credentials-target="list"></div>

    <%# ═══ Add Credential Modal ═══ %>
    <div class="modal-overlay" data-azure-credentials-target="addOverlay" data-action="click->azure-credentials#backdropClose">
      <div class="modal-panel" style="max-width:520px;">
        <div class="modal-header">
          <h3 class="modal-title">Add Azure Credential</h3>
          <button class="modal-close" data-action="click->azure-credentials#closeAdd" aria-label="Close">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Name</label>
            <input type="text" class="form-input" placeholder="e.g. Production Read-Only" data-azure-credentials-target="addName">
          </div>
          <div class="form-group">
            <label class="form-label">Tenant ID *</label>
            <input type="text" class="form-input" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" data-azure-credentials-target="addTenantId">
          </div>
          <div class="form-group">
            <label class="form-label">Client ID *</label>
            <input type="text" class="form-input" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" data-azure-credentials-target="addClientId">
          </div>
          <div class="form-group">
            <label class="form-label">Client Secret *</label>
            <input type="password" class="form-input" placeholder="Client secret value" data-azure-credentials-target="addClientSecret">
          </div>
          <div class="form-group">
            <label class="form-label">Credential Type</label>
            <div style="display:flex;gap:16px;margin-top:4px;">
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">
                <input type="radio" name="credential_type" value="read_only" checked style="accent-color:var(--green);"> Read-only
              </label>
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">
                <input type="radio" name="credential_type" value="admin" style="accent-color:var(--green);"> Admin
              </label>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Expiration Date</label>
            <input type="date" class="form-input" data-azure-credentials-target="addExpDate">
          </div>
          <p data-azure-credentials-target="addError" style="color:var(--red);font-size:12px;min-height:16px;"></p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-action="click->azure-credentials#closeAdd">Cancel</button>
          <button type="button" class="btn btn-ghost" data-action="click->azure-credentials#testCredentials">Test</button>
          <button type="button" class="btn btn-green" data-action="click->azure-credentials#saveCredential" data-azure-credentials-target="addSaveBtn">Save</button>
        </div>
      </div>
    </div>

    <%# ═══ Test Results Modal ═══ %>
    <div class="modal-overlay" data-azure-credentials-target="testOverlay" data-action="click->azure-credentials#backdropClose">
      <div class="modal-panel" style="max-width:480px;">
        <div class="modal-header">
          <h3 class="modal-title">Test Results</h3>
          <button class="modal-close" data-action="click->azure-credentials#closeTest" aria-label="Close">&times;</button>
        </div>
        <div class="modal-body" data-azure-credentials-target="testBody"></div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-action="click->azure-credentials#closeTest">Close</button>
        </div>
      </div>
    </div>

    <%# ═══ Delete Confirmation Modal ═══ %>
    <div class="modal-overlay" data-azure-credentials-target="deleteOverlay" data-action="click->azure-credentials#backdropClose">
      <div class="modal-panel" style="max-width:420px;">
        <div class="modal-header">
          <h3 class="modal-title" style="color:var(--red);">Delete Credential</h3>
          <button class="modal-close" data-action="click->azure-credentials#closeDelete" aria-label="Close">&times;</button>
        </div>
        <div class="modal-body">
          <p style="font-size:13px;color:var(--text-secondary);">
            Are you sure you want to delete <span style="font-weight:600;color:var(--text-primary);" data-azure-credentials-target="deleteCredName"></span>? This action cannot be undone.
          </p>
          <input type="hidden" data-azure-credentials-target="deleteCredId">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-action="click->azure-credentials#closeDelete">Cancel</button>
          <button type="button" class="btn btn-danger" data-action="click->azure-credentials#confirmDelete">Delete</button>
        </div>
      </div>
    </div>
  </div>

<% elsif current_tab == "integrations" %>
  <h2 style="font-size:18px;font-weight:700;margin-bottom:4px;">Integrations</h2>
  <p style="font-size:12px;color:var(--text-secondary);margin-bottom:20px;">Manage FinOps, SecOps, and Monitoring integrations.</p>
  <%= render "shared/empty_state", icon: "🔌", title: "Coming soon", description: "Integration management will be available here." %>

<% elsif current_tab == "general" %>
  <h2 style="font-size:18px;font-weight:700;margin-bottom:4px;">General</h2>
  <p style="font-size:12px;color:var(--text-secondary);margin-bottom:20px;">Project settings and configuration.</p>
  <div class="card" style="max-width:560px;">
    <div class="detail-grid">
      <div class="detail-item">
        <span class="detail-label">Project Name</span>
        <span class="detail-value"><%= @project.name %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Provider</span>
        <span class="detail-value"><%= @project.provider&.upcase || "—" %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">UUID</span>
        <span class="detail-value mono"><%= @project.uuid %></span>
      </div>
      <div class="detail-item">
        <span class="detail-label">Environments</span>
        <span class="detail-value"><%= @environments.size %></span>
      </div>
    </div>
  </div>

<% else %>
  <%# ═══════════════════════════════════════════════════
      Environments (default)
      ═══════════════════════════════════════════════════ %>
  <% if provider == "aws" %>
    <div data-controller="aws-onboard"
         data-action="keydown@document->aws-onboard#closeOnEscape"
         data-aws-onboard-validate-url-value="<%= validate_customer_project_environments_path(params[:customer_uuid], @project.uuid) %>"
         data-aws-onboard-customer-uuid-value="<%= @customer.uuid %>"
         data-aws-onboard-project-uuid-value="<%= @project.uuid %>">
  <% elsif provider == "azure" %>
    <div data-controller="azure-onboard"
         data-action="keydown@document->azure-onboard#closeOnEscape"
         data-azure-onboard-credentials-url-value="<%= customer_project_azure_credentials_path(params[:customer_uuid], @project.uuid) %>"
         data-azure-onboard-test-url-value="<%= test_customer_project_azure_credentials_path(params[:customer_uuid], @project.uuid) %>"
         data-azure-onboard-create-url-value="<%= customer_project_environments_path(params[:customer_uuid], @project.uuid) %>"
         data-azure-onboard-customer-uuid-value="<%= @customer.uuid %>"
         data-azure-onboard-project-uuid-value="<%= @project.uuid %>">
  <% else %>
    <div>
  <% end %>

    <div class="page-header">
      <div>
        <h1 class="page-title">Environments</h1>
        <p style="font-size:12px;color:var(--text-secondary);margin-top:2px;">Manage cloud environments linked to this project.</p>
      </div>
      <div class="header-actions">
        <% if can_manage_resource? %>
          <% if provider == "aws" %>
            <button class="btn btn-green btn-sm" data-action="click->aws-onboard#open">+ Add Environment</button>
          <% elsif provider == "azure" %>
            <button class="btn btn-green btn-sm" data-action="click->azure-onboard#open">+ Add Environment</button>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @environments.any? %>
      <div class="entity-grid">
        <% @environments.each do |env| %>
          <% env_color = case env.environment_type
               when 'production' then '#ef4444'
               when 'acceptance' then '#f59e0b'
               else '#3b82f6'
             end %>
          <% local_env = LocalEnvironment.find_by(aws_account_id: env.account_id) || LocalEnvironment.find_by(azure_subscription_id: env.account_id) %>
          <% if local_env %>
            <%= link_to canvas_path(local_env), class: "entity-card", style: "--accent-color: #{env_color};", data: { name: env.name } do %>
              <div class="entity-card-top">
                <div class="entity-card-name"><%= env.name %></div>
                <div class="entity-card-badges">
                  <% if env.environment_type.present? %>
                    <% badge_class = case env.environment_type
                         when 'production' then 'badge-prd'
                         when 'acceptance' then 'badge-acc'
                         else 'badge-dev'
                       end %>
                    <span class="badge <%= badge_class %>"><%= env.environment_type.humanize %></span>
                  <% end %>
                </div>
              </div>
              <% if env.account_id.present? %>
                <div class="entity-card-meta"><%= env.account_id %></div>
              <% end %>
              <div class="entity-card-footer">
                <div class="entity-card-stat">
                  <div class="entity-card-dot" style="background: <%= env_color %>;"></div>
                  🎨 Canvas linked
                </div>
                <span class="entity-card-arrow">→</span>
              </div>
            <% end %>
          <% else %>
            <div class="entity-card" style="--accent-color: <%= env_color %>; cursor: default;" data-name="<%= env.name %>">
              <div class="entity-card-top">
                <div class="entity-card-name"><%= env.name %></div>
                <div class="entity-card-badges">
                  <% if env.environment_type.present? %>
                    <% badge_class = case env.environment_type
                         when 'production' then 'badge-prd'
                         when 'acceptance' then 'badge-acc'
                         else 'badge-dev'
                       end %>
                    <span class="badge <%= badge_class %>"><%= env.environment_type.humanize %></span>
                  <% end %>
                </div>
              </div>
              <% if env.account_id.present? %>
                <div class="entity-card-meta"><%= env.account_id %></div>
              <% end %>
              <div class="entity-card-footer">
                <div class="entity-card-stat" style="color:var(--text-muted);">
                  No canvas linked
                </div>
              </div>
            </div>
          <% end %>
        <% end %>

        <%# Add card %>
        <% if can_manage_resource? %>
          <% if provider == "aws" %>
            <div class="entity-card entity-card-add" data-action="click->aws-onboard#open" style="cursor:pointer;">
              <div class="entity-add-icon">+</div>
              <span>Add Environment</span>
            </div>
          <% elsif provider == "azure" %>
            <div class="entity-card entity-card-add" data-action="click->azure-onboard#open" style="cursor:pointer;">
              <div class="entity-add-icon">+</div>
              <span>Add Environment</span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", icon: "🌍", title: "No environments yet", description: "Add an environment to get started." %>
    <% end %>

    <%# ═══ Canvas Environments (from local DB) ═══ %>
    <% canvas_envs = LocalEnvironment.includes(local_project: :local_customer).order(:env_type) %>
    <div style="margin-top:32px;border-top:1px solid var(--border);padding-top:24px;">
      <div class="page-header">
        <div>
          <h2 class="page-title" style="font-size:18px;">🎨 Canvas Environments</h2>
          <p style="font-size:12px;color:var(--text-secondary);margin-top:2px;">Infrastructure-as-Code canvas for designing and deploying resources.</p>
        </div>
        <div class="header-actions">
          <% if can_manage_resource? %>
            <button class="btn btn-green btn-sm" onclick="document.getElementById('create-canvas-modal').style.display='flex'">+ Create Canvas</button>
          <% end %>
        </div>
      </div>

      <% if canvas_envs.any? %>
        <div class="entity-grid">
          <% canvas_envs.each do |cenv| %>
            <% canvas_color = case cenv.env_type
                 when 'prd' then '#ef4444'
                 when 'acc' then '#f59e0b'
                 else '#3b82f6'
               end %>
            <% linked_account = cenv.aws_account_id || cenv.azure_subscription_id || cenv.gcp_project_id %>
            <%= link_to canvas_path(cenv), class: "entity-card", style: "--accent-color: #{canvas_color}; text-decoration:none;" do %>
              <div class="entity-card-top">
                <div class="entity-card-name"><%= cenv.name.capitalize %></div>
                <div class="entity-card-badges">
                  <% badge_class = case cenv.env_type
                       when 'prd' then 'badge-prd'
                       when 'acc' then 'badge-acc'
                       else 'badge-dev'
                     end %>
                  <span class="badge <%= badge_class %>"><%= cenv.env_type.upcase %></span>
                </div>
              </div>
              <div class="entity-card-meta"><%= cenv.local_project.name %> · <%= cenv.cloud_provider.upcase %> · <%= cenv.region %></div>
              <% if linked_account %>
                <div style="margin-top:4px;font-size:10px;color:var(--text-muted);">
                  🔗 <span class="mono"><%= linked_account %></span>
                </div>
              <% end %>
              <div class="entity-card-footer">
                <div class="entity-card-stat">
                  <div class="entity-card-dot" style="background: <%= canvas_color %>;"></div>
                  <%= cenv.cloud_provider.upcase %>
                </div>
                <span class="entity-card-arrow">→</span>
              </div>
            <% end %>
          <% end %>

          <%# Add canvas card %>
          <% if can_manage_resource? %>
            <div class="entity-card entity-card-add" onclick="document.getElementById('create-canvas-modal').style.display='flex'" style="cursor:pointer;">
              <div class="entity-add-icon">+</div>
              <span>Create Canvas</span>
            </div>
          <% end %>
        </div>

        <%# Canvas action buttons (link/unlink/delete) — shown below the grid %>
        <% if can_manage_resource? %>
          <div style="margin-top:16px;">
            <details style="font-size:12px;color:var(--text-secondary);">
              <summary style="cursor:pointer;user-select:none;">Manage canvas links & deletions</summary>
            <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
              <% canvas_envs.each do |cenv| %>
                <% linked_account = cenv.aws_account_id || cenv.azure_subscription_id || cenv.gcp_project_id %>
                <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);font-size:12px;">
                  <span style="font-weight:600;color:var(--text-primary);flex:1;"><%= cenv.name.capitalize %></span>
                  <% if linked_account %>
                    <span class="mono" style="color:var(--text-muted);font-size:10px;"><%= linked_account %></span>
                    <%= button_to "Unlink",
                          unlink_customer_project_canvas_environment_path(params[:customer_uuid], @project.uuid, cenv),
                          method: :patch,
                          class: "btn btn-ghost btn-sm",
                          data: { turbo_confirm: "Unlink canvas '#{cenv.name}' from account #{linked_account}?" } %>
                  <% else %>
                    <button class="btn btn-ghost btn-sm"
                            onclick="openLinkModal('<%= cenv.id %>', '<%= cenv.name %>', '<%= cenv.cloud_provider %>')">
                      🔗 Link
                    </button>
                  <% end %>
                  <button class="btn btn-ghost btn-sm"
                          style="color:var(--red);"
                          onclick="openDeleteCanvasModal('<%= cenv.id %>', '<%= j cenv.name %>')">
                    🗑
                  </button>
                </div>
              <% end %>
            </div>
          </details>
        </div>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", icon: "🎨", title: "No canvas environments yet", description: "Create a canvas to start designing infrastructure." %>
      <% end %>
    </div>

    <%# ═══ Create Canvas Modal ═══ %>
    <div id="create-canvas-modal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
      <div class="modal-panel" style="max-width:480px;">
        <div class="modal-header">
          <h3 class="modal-title">Create Canvas Environment</h3>
          <button class="modal-close" onclick="document.getElementById('create-canvas-modal').style.display='none'" aria-label="Close">&times;</button>
        </div>
        <%= form_with url: customer_project_canvas_environments_path(params[:customer_uuid], @project.uuid), method: :post, local: true do |f| %>
          <div class="modal-body">
            <div class="form-group">
              <label class="form-label">Name *</label>
              <input type="text" name="canvas_environment[name]" class="form-input" placeholder="e.g. Development" required>
            </div>
            <div class="form-group">
              <label class="form-label">Environment Type *</label>
              <select name="canvas_environment[env_type]" class="form-input" required>
                <option value="dev">Development (DEV)</option>
                <option value="acc">Acceptance (ACC)</option>
                <option value="prd">Production (PRD)</option>
                <option value="shared">Shared</option>
              </select>
            </div>
            <% if @environments.any? %>
              <div class="form-group">
                <label class="form-label">Link to environment</label>
                <select name="account_id" class="form-input">
                  <option value="">— None (link later) —</option>
                  <% @environments.each do |env| %>
                    <option value="<%= env.account_id %>" <%= @environments.size == 1 ? "selected" : "" %>><%= env.name %> (<%= env.account_id %>)</option>
                  <% end %>
                </select>
                <span style="font-size:11px;color:var(--text-muted);margin-top:2px;display:block;">Links the canvas to a cloud account so deployments can target it.</span>
              </div>
            <% end %>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="document.getElementById('create-canvas-modal').style.display='none'">Cancel</button>
            <button type="submit" class="btn btn-green">Create Canvas</button>
          </div>
        <% end %>
      </div>
    </div>

    <%# ═══ Link Canvas Modal ═══ %>
    <div id="link-canvas-modal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
      <div class="modal-panel" style="max-width:420px;">
        <div class="modal-header">
          <h3 class="modal-title">Link Canvas to Environment</h3>
          <button class="modal-close" onclick="document.getElementById('link-canvas-modal').style.display='none'" aria-label="Close">&times;</button>
        </div>
        <form id="link-canvas-form" method="post">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <div class="modal-body">
            <p style="font-size:12px;color:var(--text-secondary);margin-bottom:12px;">
              Link canvas <span id="link-canvas-name" style="font-weight:600;color:var(--text-primary);"></span> to a platform environment.
            </p>
            <div class="form-group">
              <label class="form-label" id="link-account-label">Account ID *</label>
              <% if @environments.any? %>
                <select name="account_id" class="form-input" id="link-account-select">
                  <option value="">— Select an environment —</option>
                  <% @environments.each do |env| %>
                    <option value="<%= env.account_id %>"><%= env.name %> (<%= env.account_id %>)</option>
                  <% end %>
                </select>
              <% else %>
                <input type="text" name="account_id" class="form-input" placeholder="123456789012" required>
              <% end %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="document.getElementById('link-canvas-modal').style.display='none'">Cancel</button>
            <button type="submit" class="btn btn-green">Link</button>
          </div>
        </form>
      </div>
    </div>

    <%# ═══ Delete Canvas Confirmation Modal ═══ %>
    <div id="delete-canvas-modal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
      <div class="modal-panel" style="max-width:420px;">
        <div class="modal-header">
          <h3 class="modal-title" style="color:var(--red);">Delete Canvas Environment</h3>
          <button class="modal-close" onclick="document.getElementById('delete-canvas-modal').style.display='none'" aria-label="Close">&times;</button>
        </div>
        <div class="modal-body">
          <p style="font-size:13px;color:var(--text-secondary);">
            Are you sure you want to delete <span id="delete-canvas-name" style="font-weight:600;color:var(--text-primary);"></span>?
            This will remove all resources and deployments. This action cannot be undone.
          </p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('delete-canvas-modal').style.display='none'">Cancel</button>
          <form id="delete-canvas-form" method="post" style="margin:0;">
            <input type="hidden" name="_method" value="delete">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <button type="submit" class="btn btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>

    <script>
      function openDeleteCanvasModal(envId, envName) {
        document.getElementById('delete-canvas-name').textContent = envName;
        var basePath = '<%= customer_project_canvas_environments_path(params[:customer_uuid], @project.uuid) %>';
        document.getElementById('delete-canvas-form').action = basePath + '/' + envId;
        document.getElementById('delete-canvas-modal').style.display = 'flex';
      }

      function openLinkModal(envId, envName, cloudProvider) {
        document.getElementById('link-canvas-name').textContent = envName;
        var basePath = '<%= customer_project_canvas_environments_path(params[:customer_uuid], @project.uuid) %>';
        document.getElementById('link-canvas-form').action = basePath + '/' + envId + '/link';
        document.getElementById('link-account-label').textContent =
          cloudProvider === 'azure' ? 'Subscription ID *' : 'Account ID *';
        document.getElementById('link-canvas-modal').style.display = 'flex';
      }
    </script>

    <% if provider == "aws" %>
      <%# ── AWS Create Environment Modal (2-step) ── %>
      <div class="modal-overlay" data-aws-onboard-target="overlay" data-action="click->aws-onboard#backdropClose">
        <div class="modal-panel" style="max-width:560px;">
          <div class="modal-header">
            <h3 class="modal-title">Create environment</h3>
            <button class="modal-close" data-action="click->aws-onboard#close" aria-label="Close">&times;</button>
          </div>
          <div data-aws-onboard-target="stepIndicator"></div>
          <%= form_with url: customer_project_environments_path(params[:customer_uuid], @project.uuid), method: :post, id: "env-onboard-form" do %>
            <%# STEP 1 %>
            <div data-aws-onboard-target="step1">
              <div class="modal-body">
                <div class="form-group">
                  <label class="form-label">Environment name *</label>
                  <input type="text" name="environment_name" class="form-input" placeholder="My AWS Environment" required data-aws-onboard-target="environmentName">
                </div>
                <div class="form-group">
                  <label class="form-label">Account ID *</label>
                  <input type="text" name="account_id" class="form-input" placeholder="123456789012" required data-aws-onboard-target="accountId">
                </div>
                <div class="form-group">
                  <label class="form-label">Role Name *</label>
                  <input type="text" name="role_name" class="form-input" placeholder="FactorFifty-Admin" required data-aws-onboard-target="roleName">
                </div>
                <div class="form-group" style="margin-bottom:8px;">
                  <label class="form-label">External ID</label>
                  <div style="display:flex;gap:8px;align-items:center;">
                    <input type="text" name="external_id" class="form-input" readonly style="background:var(--bg-elevated);flex:1;" data-aws-onboard-target="externalId">
                    <button type="button" class="btn btn-ghost btn-sm" style="flex-shrink:0;height:38px;" data-action="click->aws-onboard#copyExternalId" title="Copy to clipboard">📋</button>
                  </div>
                </div>
                <div style="font-size:12px;margin-top:0;">
                  <a href="https://docs.factorfifty.com/environments/create-a-new-environment/aws" target="_blank" style="color:var(--green);text-decoration:none;">Read the docs →</a>
                </div>
                <p data-aws-onboard-target="validateError" style="color:var(--red);font-size:12px;margin-top:8px;min-height:16px;"></p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-action="click->aws-onboard#close">Cancel</button>
                <button type="button" class="btn btn-green" data-action="click->aws-onboard#validate" data-aws-onboard-target="validateBtn">Validate</button>
              </div>
            </div>
            <%# STEP 2 %>
            <div data-aws-onboard-target="step2" style="display:none;">
              <div class="modal-body">
                <div class="form-group">
                  <label class="form-label">SLA *</label>
                  <select name="sla" class="form-input" required data-aws-onboard-target="sla" data-action="change->aws-onboard#slaChanged">
                    <option value="production">Production</option>
                    <option value="non_production">Non-Production</option>
                    <option value="unmanaged">Unmanaged</option>
                  </select>
                </div>
                <div style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
                  <label class="form-label" style="margin-bottom:12px;">Enable Integrations</label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" name="finops_enabled" value="1" data-aws-onboard-target="finops" style="width:16px;height:16px;accent-color:var(--green);"> FinOps
                  </label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" name="secops_enabled" value="1" data-aws-onboard-target="secops" style="width:16px;height:16px;accent-color:var(--green);"> SecOps
                  </label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:4px;font-size:13px;">
                    <input type="checkbox" name="monitoring_enabled" value="1" data-aws-onboard-target="monitoring" disabled checked style="width:16px;height:16px;accent-color:var(--green);"> Monitoring
                  </label>
                  <p data-aws-onboard-target="monitoringNote" style="font-size:11px;color:var(--text-muted);margin-left:26px;">
                    <span class="badge" style="background:var(--green-dim);color:var(--green);font-size:10px;">Monitoring</span>
                    will be configured for <span style="font-weight:600;">Production</span>
                  </p>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-action="click->aws-onboard#goBack">Back</button>
                <input type="submit" class="btn btn-green" value="Save">
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if provider == "azure" %>
      <%# ── Azure Create Environment Modal (2-step) ── %>
      <div class="modal-overlay" data-azure-onboard-target="overlay" data-action="click->azure-onboard#backdropClose">
        <div class="modal-panel" style="max-width:560px;">
          <div class="modal-header">
            <h3 class="modal-title">Create environment</h3>
            <button class="modal-close" data-action="click->azure-onboard#close" aria-label="Close">&times;</button>
          </div>
          <div data-azure-onboard-target="stepIndicator"></div>

          <%# No credentials message %>
          <div data-azure-onboard-target="noCreds" style="display:none;"></div>

          <%# STEP 1 — Credentials + Subscription %>
          <div data-azure-onboard-target="credsForm" style="display:none;">
            <div data-azure-onboard-target="step1">
              <div class="modal-body">
                <div class="form-group">
                  <label class="form-label">Environment name *</label>
                  <input type="text" class="form-input" placeholder="My Azure Environment" data-azure-onboard-target="environmentName">
                </div>
                <div class="form-group">
                  <label class="form-label">Admin Credential</label>
                  <select class="form-input" data-azure-onboard-target="adminCred" data-action="change->azure-onboard#adminCredChanged">
                    <option value="">Loading…</option>
                  </select>
                  <span style="font-size:11px;color:var(--text-muted);">Optional — only needed for write operations.</span>
                </div>
                <div class="form-group">
                  <label class="form-label">Read-only Credential *</label>
                  <select class="form-input" data-azure-onboard-target="readOnlyCred" data-action="change->azure-onboard#readOnlyCredChanged">
                    <option value="">Loading…</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Subscription ID *</label>
                  <input type="text" class="form-input" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" data-azure-onboard-target="subscription">
                </div>
                <p data-azure-onboard-target="validateError" style="color:var(--red);font-size:12px;min-height:16px;"></p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-action="click->azure-onboard#close">Cancel</button>
                <button type="button" class="btn btn-green" data-action="click->azure-onboard#validate" data-azure-onboard-target="validateBtn">Validate</button>
              </div>
            </div>

            <%# STEP 2 — SLA + Integrations %>
            <div data-azure-onboard-target="step2" style="display:none;">
              <div class="modal-body">
                <div class="form-group">
                  <label class="form-label">SLA *</label>
                  <select class="form-input" data-azure-onboard-target="sla" data-action="change->azure-onboard#slaChanged">
                    <option value="production">Production</option>
                    <option value="non_production">Non-Production</option>
                    <option value="unmanaged">Unmanaged</option>
                  </select>
                </div>
                <div style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
                  <label class="form-label" style="margin-bottom:12px;">Enable Integrations</label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" value="1" data-azure-onboard-target="finops" style="width:16px;height:16px;accent-color:var(--green);"> FinOps
                  </label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" value="1" data-azure-onboard-target="secops" style="width:16px;height:16px;accent-color:var(--green);"> SecOps
                  </label>
                  <label style="display:flex;align-items:center;gap:10px;margin-bottom:4px;font-size:13px;">
                    <input type="checkbox" value="1" data-azure-onboard-target="monitoring" disabled checked style="width:16px;height:16px;accent-color:var(--green);"> Monitoring
                  </label>
                  <p data-azure-onboard-target="monitoringNote" style="font-size:11px;color:var(--text-muted);margin-left:26px;">
                    <span class="badge" style="background:var(--green-dim);color:var(--green);font-size:10px;">Monitoring</span>
                    will be configured for <span style="font-weight:600;">Production</span>
                  </p>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-action="click->azure-onboard#goBack">Back</button>
                <button type="button" class="btn btn-green" data-action="click->azure-onboard#save">Save</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

  </div>
<% end %>
