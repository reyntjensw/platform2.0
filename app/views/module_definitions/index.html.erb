<% content_for(:title) { "Module Registry — Factor Fifty" } %>

<div class="page-header">
  <div>
    <h1 class="page-title">Module Registry</h1>
    <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">All registered modules with their renderers, versions, and field mappings.</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-ghost btn-sm">↗ Export</button>
    <%= link_to "+ New Module", new_module_import_path, class: "btn btn-green btn-sm" %>
  </div>
</div>

<div data-controller="filter">
  <div class="mod-toolbar">
    <div class="mod-search-wrap">
      <svg class="mod-search-icon" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input class="mod-search-input" type="text" placeholder="Search modules…"
             data-action="input->filter#search" data-filter-target="searchInput"
             aria-label="Search modules">
    </div>

    <select class="mod-filter-select" data-action="change->filter#setProvider" data-filter-target="providerSelect">
      <option value="">All Clouds</option>
      <% @cloud_providers.each do |cp| %>
        <option value="<%= cp %>" <%= 'selected' if params[:cloud_provider] == cp %>><%= cp.upcase %></option>
      <% end %>
    </select>

    <select class="mod-filter-select" data-action="change->filter#setStatus" data-filter-target="statusSelect">
      <option value="">All Statuses</option>
      <option value="live" <%= 'selected' if params[:status] == 'live' %>>Live</option>
      <option value="draft" <%= 'selected' if params[:status] == 'draft' %>>Draft</option>
      <option value="deprecated" <%= 'selected' if params[:status] == 'deprecated' %>>Deprecated</option>
    </select>

    <span class="mod-count-badge" data-filter-target="count"><%= @modules.size %> modules</span>
  </div>

  <div class="mod-table-wrap" data-filter-target="grid">
    <% if @modules.any? %>
      <table class="mod-tbl mod-tbl--registry">
        <colgroup>
          <col><col><col><col><col><col><col><col>
        </colgroup>
        <thead>
          <tr>
            <th>Module</th>
            <th>Cloud</th>
            <th>Category</th>
            <th>Renderers</th>
            <th>Fields</th>
            <th>Version</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @modules.each do |mod| %>
            <tr class="mod-tbl__row"
                data-category="<%= mod.category %>"
                data-cloud="<%= mod.cloud_provider %>"
                data-status="<%= mod.status %>"
                data-name="<%= mod.display_name.downcase %>"
                data-href="<%= module_path(mod) %>"
                onclick="if(!event.target.closest('a,button')){Turbo.visit(this.dataset.href)}"
                style="cursor:pointer;">
              <td>
                <div class="mod-cell">
                  <div class="mod-icon mod-icon--<%= mod.category %>"><%= mod.icon %></div>
                  <span class="mod-cell-name"><%= mod.display_name %></span>
                </div>
              </td>
              <td>
                <span class="mod-cloud-badge mod-cloud-<%= mod.cloud_provider %>"><%= mod.cloud_provider.upcase %></span>
              </td>
              <td><span class="mod-category-text"><%= mod.category.capitalize %></span></td>
              <td>
                <% if mod.module_renderers.any? %>
                  <% mod.module_renderers.each do |r| %>
                    <% engine_class = case r.engine
                         when "opentofu" then "mod-renderer-tofu"
                         when "cloudformation" then "mod-renderer-cf"
                         when "arm" then "mod-renderer-arm"
                         else "mod-renderer-tofu"
                       end %>
                    <span class="mod-renderer-badge <%= engine_class %>"><%= r.engine == "opentofu" ? "OpenTofu" : r.engine.capitalize %></span>
                  <% end %>
                <% else %>
                  <span class="mod-renderer-badge" style="background:rgba(245,158,11,0.12);color:#f59e0b;border-color:rgba(245,158,11,0.2);">Canvas only</span>
                <% end %>
              </td>
              <td>
                <span class="mod-fields-text">
                  <% inputs = mod.module_fields.select { |f| f.classification == "user_config" }.size %>
                  <% outputs = mod.module_outputs.size rescue 0 %>
                  <%= inputs %> inputs<span class="mod-fields-sep">·</span><%= outputs %> outputs
                </span>
              </td>
              <td><span class="mod-version-text"><%= (mod.version || "0.0.0").to_s.start_with?("v") ? mod.version : "v#{mod.version || "0.0.0"}" %></span></td>
              <td>
                <% case mod.status %>
                <% when "live" %>
                  <span class="mod-status-badge mod-status-live"><span class="mod-status-dot"></span>Live</span>
                <% when "draft" %>
                  <span class="mod-status-badge mod-status-draft"><span class="mod-status-dot"></span>Draft</span>
                <% when "deprecated" %>
                  <span class="mod-status-badge mod-status-deprecated"><span class="mod-status-dot"></span>Deprecated</span>
                <% end %>
              </td>
              <td>
                <div class="mod-actions-cell">
                  <%= link_to "View", module_path(mod), class: "mod-action-btn" %>
                  <%= link_to "Edit", edit_module_path(mod), class: "mod-action-btn mod-action-btn-primary" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="mod-empty-state">
        <p>No modules match your filters.</p>
        <%= link_to "Import a module →", new_module_import_path, style: "color:var(--green);" %>
      </div>
    <% end %>
  </div>
</div>
