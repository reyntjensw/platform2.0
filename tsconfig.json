{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "app/javascript/components/*"
            ],
            "@controllers/*": [
                "app/javascript/controllers/*"
            ]
        }
    },
    "include": [
        "app/javascript/**/*.ts",
        "app/javascript/**/*.tsx"
    ],
    "exclude": [
        "node_modules"
    ]
}