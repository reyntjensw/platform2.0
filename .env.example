# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5433/factorfifty_development

# Redis
REDIS_URL=redis://localhost:6379/0

# Keycloak OIDC
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=factorfifty
KEYCLOAK_CLIENT_ID=factorfifty
KEYCLOAK_CLIENT_SECRET=your-client-secret

# CS Internal API
CS_INTERNAL_API_URL=https://internal-api.example.com

# Pipeline Service
PIPELINE_SERVICE_URL=http://localhost:8000
PIPELINE_SERVICE_TOKEN=dev-token

# App URL (for pipeline callbacks)
APP_URL=http://localhost:3000

# OpenTofu State Backend
S3_TFSTATE_BUCKET=f50-tfstate
DYNAMODB_TFLOCK_TABLE=f50-tflock

# Rails
SECRET_KEY_BASE=generate-with-rails-secret
RAILS_ENV=development
